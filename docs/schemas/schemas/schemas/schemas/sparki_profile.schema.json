{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SPARKIProfile",
  "type": "object",
  "required": ["enabled", "derived_scores", "actions"],
  "properties": {
    "enabled": { "type": "boolean" },
    "derived_scores": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["allow", "soften", "queue", "deny", "recommend_inspection"]
      }
    }
  }
}
